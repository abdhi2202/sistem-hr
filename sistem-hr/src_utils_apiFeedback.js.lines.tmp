1:export function getApiFieldErrors(error) {
2:  const payload = error?.payload;
3:
4:  if (payload && typeof payload === 'object' && payload.errors && typeof payload.errors === 'object') {
5:    return payload.errors;
6:  }
7:
8:  return {};
9:}
10:
11:export function getFieldError(fieldErrors, ...keys) {
12:  for (const key of keys) {
13:    const value = fieldErrors?.[key];
14:
15:    if (Array.isArray(value) && value.length > 0) {
16:      return value[0];
17:    }
18:
19:    if (typeof value === 'string' && value) {
20:      return value;
21:    }
22:  }
23:
24:  return '';
25:}
