27:export function getApiErrorMessage(error, fallbackMessage) {
28:  const fieldErrors = getApiFieldErrors(error);
29:  const firstFieldError = Object.values(fieldErrors)[0];
30:
31:  if (Array.isArray(firstFieldError) && firstFieldError[0]) {
32:    return firstFieldError[0];
33:  }
34:
35:  if (typeof firstFieldError === 'string' && firstFieldError) {
36:    return firstFieldError;
37:  }
38:
39:  return error?.message || fallbackMessage;
40:}
